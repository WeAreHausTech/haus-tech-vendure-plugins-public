{
  "name": "@haus-tech/haus-vendure-plugins-public",
  "author": "Haus Tech",
  "license": "ISC",
  "version": "1.0.0",
  "description": "Plugins for the Vendure ecommerce platform that provide extended functionality",
  "scripts": {
    "test": "nx run-many --target=test --all --exclude=@haus-tech/haus-vendure-plugins-public",
    "test:affected": "nx affected --target=test --exclude=@haus-tech/haus-vendure-plugins-public",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "upgrade:vendure": "nx run-many --target=upgrade:vendure --all",
    "upgrade:vendure:all": "npm update @vendure/* --save",
    "remove-node-modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "update-readmes": "tsx ./scripts/update-readmes.ts",
    "security:audit": "yarn npm audit -A -R --severity high --environment production"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@haus-tech/prettier-config": "1.0.3",
    "@nx/devkit": "22.7.1",
    "@nx/eslint": "21.4.1",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/js": "22.7.1",
    "@nx/vite": "21.4.1",
    "@nx/web": "21.4.1",
    "@nx/workspace": "21.4.1",
    "@swc-node/register": "1.9.2",
    "@swc/core": "1.15.21",
    "@swc/helpers": "0.5.17",
    "@types/express": "4.17.25",
    "@types/lodash-es": "4.17.12",
    "@types/multer": "1.4.13",
    "@types/node": "20.19.35",
    "@types/progress": "2.0.7",
    "@types/slug": "5.0.9",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vendure/admin-ui-plugin": "3.5",
    "@vendure/asset-server-plugin": "3.5",
    "@vendure/core": "3.6.3",
    "@vendure/dashboard": "3.5.5",
    "@vendure/elasticsearch-plugin": "3.5",
    "@vendure/email-plugin": "3.6.3",
    "@vendure/testing": "3.6.0",
    "@vendure/ui-devkit": "3.6.3",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "copyfiles": "2.4.1",
    "csv-writer": "1.6.0",
    "eslint": "9.39.3",
    "eslint-plugin-import": "2.32.0",
    "graphql-tag": "2.12.6",
    "jiti": "2.5.1",
    "lodash-es": "4.18.1",
    "multer": "2.1.1",
    "nx": "22.7.1",
    "prettier": "3.6.2",
    "rimraf": "4.4.1",
    "slug": "9.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "unplugin-swc": "1.5.9",
    "vite": "8.0.13",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.6",
    "vitest-canvas-mock": "0.3.3"
  },
  "packageManager": "yarn@4.15.0",
  "dependencies": {
    "@nestjs/graphql": "13.4.0",
    "bottleneck": "2.19.5",
    "graphql": "16.14.0"
  }
}
