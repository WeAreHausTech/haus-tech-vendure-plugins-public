    "zone.js": "^0.15.0"
  },
  "packageManager": "yarn@4.9.0",
  "dependencies": {
    "@angular/common": "^19.2.9",
    "@angular/core": "^19.2.9",
    "@angular/forms": "^19.2.9",
    "@angular/platform-browser": "^19.2.9",
    "@angular/router": "^19.2.9",
    "@apollo/server": "4.11.2",
    "@nestjs/apollo": "~12.2.1",
    "@nestjs/common": "~10.4.12",
