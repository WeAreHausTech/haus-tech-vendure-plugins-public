{
  "name": "@haus-tech/haus-vendure-plugins-public",
  "author": "Haus Tech",
  "license": "ISC",
  "version": "0.0.1",
  "description": "Plugins for the Vendure ecommerce platform that provide extended functionality",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "nx run-many --target=build --all --exclude=example-plugin",
    "build:affected": "nx affected --target=build --exclude=example-plugin",
    "lint": "nx run-many --target=lint --all --exclude=example-plugin",
    "lint:affected": "nx affected --target=lint --exclude=example-plugin",
    "upgrade:vendure": "nx run-many --target=upgrade:vendure --all",
    "upgrade:vendure:all": "npm update @vendure/* --save",
    "remove-node-modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "bump-all-versions": "tsx ./scripts/bump-versions.ts"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@haus-tech/prettier-config": "^1.0.3",
    "@nrwl/tao": "19.8.4",
    "@nrwl/workspace": "19.8.4",
    "@nx/devkit": "^21.0.3",
    "@nx/eslint": "^20.8.1",
    "@nx/js": "21.0.3",
    "@nx/vite": "20.8.1",
    "@nx/web": "20.8.1",
    "@nx/workspace": "^21.0.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.30",
    "@types/progress": "^2.0.7",
    "@types/slug": "^5.0.9",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vendure/admin-ui-plugin": "3.1.1",
    "@vendure/asset-server-plugin": "3.1.1",
    "@vendure/core": "3.1.1",
    "@vendure/elasticsearch-plugin": "3.1.1",
    "@vendure/testing": "^3.2.4",
    "@vendure/ui-devkit": "3.1.1",
    "@vitest/coverage-v8": "3.1.3",
    "@vitest/ui": "^3.0.0",
    "copyfiles": "^2.4.1",
    "csv-writer": "^1.6.0",
    "eslint": "^9.25.1",
    "graphql-tag": "^2.12.6",
    "jiti": "2.4.2",
    "multer": "^1.4.5-lts.1",
    "nx": "^21.0.3",
    "prettier": "3.5.3",
    "rimraf": "^4.4.1",
    "slug": "^9.1.0",
    "ts-node": "10.9.2",
    "tsx": "^4.19.4",
    "typescript": "~5.7.2",
