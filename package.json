{
  "name": "@haus-tech/haus-vendure-plugins-public",
  "author": "Haus Tech",
  "license": "ISC",
  "version": "1.0.0",
  "description": "Plugins for the Vendure ecommerce platform that provide extended functionality",
  "scripts": {
    "test": "nx run-many --target=test --all --exclude=@haus-tech/haus-vendure-plugins-public",
    "test:affected": "nx affected --target=test --exclude=@haus-tech/haus-vendure-plugins-public",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "upgrade:vendure": "nx run-many --target=upgrade:vendure --all",
    "upgrade:vendure:all": "npm update @vendure/* --save",
    "remove-node-modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "update-readmes": "tsx ./scripts/update-readmes.ts"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@haus-tech/prettier-config": "^1.0.3",
    "@nx/devkit": "21.4.1",
    "@nx/eslint": "21.4.1",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/js": "21.4.1",
    "@nx/vite": "21.4.1",
    "@nx/web": "21.4.1",
    "@nx/workspace": "21.4.1",
    "@swc-node/register": "~1.9.2",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "~0.5.17",
    "@types/express": "^4.17.23",
    "@types/lodash-es": "^4",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.11",
    "@types/progress": "^2.0.7",
    "@types/slug": "^5.0.9",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vendure/admin-ui-plugin": "^3.6.0",
    "@vendure/asset-server-plugin": "^3.6.0",
    "@vendure/core": "^3.6.0",
    "@vendure/dashboard": "^3.6.0",
    "@vendure/email-plugin": "^3.6.0",
    "@vendure/testing": "^3.6.0",
    "@vendure/ui-devkit": "^3.6.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "^4.1.2",
    "copyfiles": "^2.4.1",
    "csv-writer": "^1.6.0",
    "eslint": "^9.34.0",
    "eslint-plugin-import": "^2.32.0",
    "graphql-tag": "^2.12.6",
    "jiti": "2.5.1",
    "lodash-es": "^4.17.21",
    "multer": "^1.4.5-lts.2",
    "nx": "21.4.1",
    "prettier": "3.6.2",
    "rimraf": "^4.4.1",
    "slug": "^9.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "unplugin-swc": "^1.5.9",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2",
    "vitest-canvas-mock": "^0.3.3"
  },
  "packageManager": "yarn@4.9.0",
  "dependencies": {
    "@nestjs/graphql": "^13.1.0",
    "bottleneck": "^2.19.5",
    "graphql": "16.11.0"
  }
}
