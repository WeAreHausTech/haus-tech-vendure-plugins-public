{
  "name": "@haus-tech/product-import-export-plugin",
  "version": "3.1.3",
  "description": "A Vendure plugin for importing and exporting products using a CSV file",
  "author": "Haus Tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeAreHausTech/haus-tech-vendure-plugins-public.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "scripts": {
    "start": "yarn ts-node test/dev-server.ts",
    "build": "yarn run -T rimraf dist && yarn run -T tsc && yarn run -T copyfiles -u 1 'src/ui/**/*' dist/",
    "prepublishOnly": "yarn && yarn build"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "bottleneck": "^2.19.5",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.6.0"
  },
  "peerDependencies": {
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "slug": "^9.1.0"
  }
}
