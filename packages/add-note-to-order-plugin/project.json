{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "add-note-to-order-plugin",
  "root": "packages/add-note-to-order-plugin",
  "sourceRoot": "packages/add-note-to-order-plugin/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/add-note-to-order-plugin",
        "main": "packages/add-note-to-order-plugin/src/index.ts",
        "tsConfig": "packages/add-note-to-order-plugin/tsconfig.json",
        "assets": [
          "packages/add-note-to-order-plugin/README.md",
          "packages/add-note-to-order-plugin/CHANGELOG.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "config": "vitest.config.ts",
        "passWithNoTests": true,
        "coverage": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/add-note-to-order-plugin/**/*.ts"
        ]
      }
    },
    "upgrade:vendure": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm update @vendure/* --save",
        "cwd": "packages/add-note-to-order-plugin"
      }
    },
    "version": {
      "executor": "@nx/workspace:version",
      "dependsOn": [
        "update-readme"
      ],
      "options": {
        "changelog": true,
        "push": true
      }
    },
    "update-readme": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/update-readmes.ts add-note-to-order-plugin"
      }
    }
  }
}
